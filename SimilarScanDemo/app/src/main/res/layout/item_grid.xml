<?xml version="1.0" encoding="utf-8"?>
<com.example.similarscandemo.ui.SquareFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/gridImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#1E293B" />

    <TextView
        android:id="@+id/gridBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="4dp"
        android:background="#70000000"
        android:paddingStart="6dp"
        android:paddingTop="2dp"
        android:paddingEnd="6dp"
        android:paddingBottom="2dp"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/bestBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:background="#38BDF8"
        android:paddingStart="6dp"
        android:paddingTop="2dp"
        android:paddingEnd="6dp"
        android:paddingBottom="2dp"
        android:text="Best"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/selectionIndicator"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="4dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />
</com.example.similarscandemo.ui.SquareFrameLayout>
